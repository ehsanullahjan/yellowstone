{
  "default": [
    {
      "type": "reject"
    }
  ],
  "transports": {
    "containers-storage": {
      "": [{ "type": "insecureAcceptAnything" }]
    },
    "docker-daemon": {
      "": [{ "type": "insecureAcceptAnything" }]
    },
    "docker": {
      "docker.io": [
        {
          "type": "insecureAcceptAnything"
        }
      ],
      "ghcr.io": [
        {
          "type": "insecureAcceptAnything"
        }
      ],
      "ghcr.io/ehsanullahjan/yellowstone": [
        {
          "type": "sigstoreSigned",
          "keyPath": "/etc/pki/containers/yellowstone.pub",
          "signedIdentity": {
            "type": "matchRepository"
          }
        }
      ],
      "quay.io": [
        {
          "type": "insecureAcceptAnything"
        }
      ]
    }
  }
}
